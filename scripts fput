############################################################
# Transcriptomics analyse RA vs control
# Van FASTQ naar differentiële expressie en GO-analyse
# Auteur: Lotte Huitenga
############################################################

#########################
# 1. Setup
#########################

# Working directory
setwd("C:/Users/lotte/OneDrive/TRANSCRIPTOMICS LOTTE HUITENGA CASUS")
getwd()

# Benodigde packages installeren (eenmalig) en laden
if (!requireNamespace("BiocManager", quietly = TRUE)) install.packages("BiocManager")

packages_bioc <- c("Rsubread", "Rsamtools", "DESeq2", "KEGGREST", "EnhancedVolcano", "pathview", "goseq", "org.Hs.eg.db")
for (pkg in packages_bioc) {
  if (!requireNamespace(pkg, quietly = TRUE)) {
    BiocManager::install(pkg)}}

library(Rsubread)
library(Rsamtools)
library(DESeq2)
library(KEGGREST)
library(EnhancedVolcano)
library(pathview)
library(goseq)
library(org.Hs.eg.db)

# Controle van beschikbare bestanden
list.files()


#########################
# 2. Referentiegenoom indexeren
#########################

# Referentiegenoom:
# GCF_000001405.40_GRCh38.p14_genomic.fna

buildindex(
  basename   = "ref_human",
  reference  = "GCF_000001405.40_GRCh38.p14_genomic.fna",
  memory     = 4000,
  indexSplit = TRUE)


#########################
# 3. Mapping van raw reads
#########################

# In deze analyse is single-end gebruikt:
# alleen readfile1 wordt gemapt

sample_fastq <- c(
  RA1        = "SRR4785819_1_subset40k.fastq",
  RA2        = "SRR4785820_1_subset40k.fastq",
  RA3        = "SRR4785828_1_subset40k.fastq",
  RA4        = "SRR4785831_1_subset40k.fastq",
  control1RA = "SRR4785979_1_subset40k.fastq",
  control2RA = "SRR4785980_1_subset40k.fastq",
  control3RA = "SRR4785986_1_subset40k.fastq",
  control4RA = "SRR4785988_1_subset40k.fastq")

for (sample_name in names(sample_fastq)) {
  align(
    index       = "ref_human",
    readfile1   = sample_fastq[[sample_name]],
    output_file = paste0(sample_name, ".BAM"))}


#########################
# 4. Sorteren en indexeren van BAM-bestanden
#########################

samples <- names(sample_fastq)

# BAM sorteren
lapply(samples, function(s) {
  sortBam(
    file        = paste0(s, ".BAM"),
    destination = paste0(s, ".sorted"))})

# Gesorteerde BAM indexeren
lapply(samples, function(s) {indexBam(
    file = paste0(s, ".sorted.bam"))})

# Optioneel: visualisatie in IGV
# Gebruik in IGV bij voorkeur het standaardgenoom Human (GRCh38/hg38)
# en laad vervolgens een .sorted.bam bestand als track.


#########################
# 5. Count matrix genereren
#########################

allsamples <- paste0(samples, ".sorted.bam")

count_matrix <- featureCounts(
  files                = allsamples,
  annot.ext            = "genomic.gtf",
  isGTFAnnotationFile  = TRUE,
  isPairedEnd          = FALSE,
  strandSpecific       = 0,
  GTF.featureType      = "exon",
  GTF.attrType         = "gene_id",
  useMetaFeatures      = TRUE)

# Count matrix extraheren
counts <- count_matrix$counts

# Duidelijke kolomnamen instellen
colnames(counts) <- c("RA1", "RA2", "RA3", "RA4", "control1", "control2", "control3", "control4")

# Opslaan voor hergebruik
write.csv(counts, "RA_countmatrix.csv")


#########################
# 6. Metadata opstellen
#########################

treatment_table <- data.frame(
  treatment = c("RA", "RA", "RA", "RA", "control", "control", "control", "control"))

rownames(treatment_table) <- colnames(counts)


#########################
# 7. Differentiële expressie analyse met DESeq2
#########################

# Count matrix opnieuw inladen (handig voor losse runs)
counts <- read.csv("RA_countmatrix.csv", row.names = 1)
counts <- as.matrix(counts)

dds <- DESeqDataSetFromMatrix(
  countData = counts,
  colData   = treatment_table,
  design    = ~ treatment)

dds <- DESeq(dds)
resultaten <- results(dds)

# Resultaten sorteren op adjusted p-value
resultaten_sorted <- resultaten[order(resultaten$padj), ]

# Opslaan
write.csv(as.data.frame(resultaten_sorted), "DE_results_RA_vs_control.csv")

# Overzicht van topgenen
hoogste_fold_change <- resultaten[order(resultaten$log2FoldChange, decreasing = TRUE), ]
laagste_fold_change <- resultaten[order(resultaten$log2FoldChange, decreasing = FALSE), ]
laagste_p_waarde    <- resultaten[order(resultaten$padj, decreasing = FALSE), ]

head(resultaten_sorted)
head(laagste_p_waarde)


#########################
# 8. Samenvattende statistiek
#########################

# Aantal significant opgereguleerde genen in RA
sum(resultaten$padj < 0.05 & resultaten$log2FoldChange > 1, na.rm = TRUE)

# Aantal significant neer-gereguleerde genen in RA
sum(resultaten$padj < 0.05 & resultaten$log2FoldChange < -1, na.rm = TRUE)


#########################
# 9. Volcano plot
#########################

EnhancedVolcano(
  resultaten,
  lab = rownames(resultaten),
  x   = "log2FoldChange",
  y   = "padj")

dev.copy(png, "Volcanoplot_RA_vs_control.png", width = 8, height = 10, units = "in", res = 500)
dev.off()


#########################
# 10. KEGG pathway-analyse
#########################

# Voorbeeld: humane cell cycle pathway
pathview(
  gene.data  = resultaten$log2FoldChange,
  pathway.id = "hsa04110",
  species    = "hsa",
  limit      = list(gene = 2))

# Voorbeeld: opzoeken in welke pathways TP53 voorkomt
keggLink("pathway", "hsa:7157")


#########################
# 11. GO-analyse met goseq
#########################

# Resultaten voorbereiden
res <- as.data.frame(resultaten)
res <- res[!is.na(res$padj), ]

# In deze run is gewerkt met pvalue < 0.05 om voldoende input te hebben voor GO-analyse
gene_vector <- as.integer(res$pvalue < 0.05)
names(gene_vector) <- rownames(res)

# Bias-correctie met baseMean
bias_vector <- res$baseMean
names(bias_vector) <- rownames(res)
bias_vector[is.na(bias_vector)] <- 1
bias_vector[bias_vector <= 0]   <- 1

# Probability weighting function
pwf <- nullp(gene_vector, bias.data = bias_vector)

# GO-enrichment
go_results <- goseq(pwf, genome = "hg19", id = "geneSymbol")
go_results$padj <- p.adjust(go_results$over_represented_pvalue, method = "BH")

# Significante GO-termen
go_sig <- go_results[go_results$padj < 0.05, ]
go_sig <- go_sig[order(go_sig$padj), ]

# Top GO-termen op ruwe p-waarde
go_top <- go_results[order(go_results$over_represented_pvalue), ]

# Opslaan
write.csv(go_results, "GO_all_results_RA_vs_control.csv")
write.csv(go_top, "GO_top_terms_RA_vs_control.csv")
write.csv(go_sig, "GO_sig_terms_RA_vs_control.csv")

# Overzicht
nrow(go_sig)
head(go_top, 10)
sum(gene_vector == 1)
sum(go_results$numDEInCat > 0)
table(go_results$numDEInCat > 0)

